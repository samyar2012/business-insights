PORT=3001
CORS_ORIGIN=http://localhost:5173

# Option A — full URI (encode special chars in password: ? → %3F)
# SUPABASE_DB_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Option B — recommended if password has ? # @ symbols
DB_HOST=db.YOUR_PROJECT_REF.supabase.co
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=YOUR_DATABASE_PASSWORD
DB_NAME=postgres

# Use a long random secret (at least 32 chars).
JWT_SECRET=replace_with_strong_random_secret
JWT_EXPIRES_IN=1d

# Web search (mock works with no API keys — used for external research only, not website crawling)
SEARCH_PROVIDER=mock
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=
BRAVE_SEARCH_API_KEY=
TAVILY_API_KEY=
SERPAPI_API_KEY=
DAILY_SEARCH_LIMIT=20

# Google Safe Browsing (optional — without key, safety_score uses partial credit and safety_status=unknown)
GOOGLE_SAFE_BROWSING_API_KEY=
SAFE_BROWSING_TIMEOUT_MS=8000

# Optional visual audit (Playwright screenshots + layout metrics for UX scoring)
VISUAL_AUDIT_ENABLED=false
VISUAL_AUDIT_TIMEOUT_MS=15000

CRAWLER_USER_AGENT=BusinessInsights-Crawler/1.0 (+http://localhost:5173)
CRAWLER_TIMEOUT_MS=10000
CRAWLER_MAX_BYTES=3145728
CRAWLER_DOMAIN_DELAY_MS=300
CRAWLER_USE_PLAYWRIGHT=false
DAILY_CRAWL_LIMIT=5
GLOBAL_CRAWL_CONCURRENCY=3
APP_URL=http://localhost:5173

# Optional UX ML model (blends 30% ML prediction with 70% deterministic UX/UI score)
UX_MODEL_ENABLED=false
UX_MODEL_PATH=ml/ux_model/models/ux_score_model.joblib
UX_MODEL_PYTHON=python
UX_MODEL_TIMEOUT_MS=8000

AI_PROVIDER=mock
CUSTOM_AI_BASE_URL=
CUSTOM_AI_API_KEY=
CUSTOM_AI_MODEL=business-insights-ai
