# --- Core ---
NODE_ENV=development
PORT=3001
# Supabase Auth (optional). If unset, backend uses local SQLite auth.
SUPABASE_URL=
SUPABASE_ANON_KEY=
# JWT secret from Supabase dashboard (Settings -> API -> JWT Secret). Strongly recommended in production.
SUPABASE_JWT_SECRET=

# Auth: in production use a long random secret (min 32 characters).
JWT_SECRET=dev-secret-change-me-not-for-production
ADMIN_SECRET=change-me-admin-secret

# Python: path to interpreter and optional override for the churn CLI
PYTHON_BIN=python
# PYTHON_PREDICT_CLI=./python/predict_churn_cli.py

# --- Production networking ---
# Comma-separated list of allowed browser origins (e.g. https://app.example.com)
# CORS_ORIGIN=https://app.example.com
# Behind a reverse proxy / load balancer that sets X-Forwarded-For:
# TRUST_PROXY=1

# --- Limits (optional overrides) ---
# UPLOAD_MAX_BYTES=12582912
# AUTH_RATE_LIMIT_MAX=40
# API_RATE_LIMIT_MAX=200x 

# --- Optional paid helper: merge missing PDF fields via OpenAI (not required) ---
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
